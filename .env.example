# ─────────────────────────────────────────────────────────────
#  claude-local-proxy  —  Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git (it's in .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Provider ─────────────────────────────────────────────────
# "anthropic" uses the official Anthropic Messages API.
# "remote"    uses REMOTE_INFERENCE_URL (HuggingFace, Replicate, etc.)
API_PROVIDER=anthropic

# Your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# For API_PROVIDER=remote: POST endpoint that accepts
# { "inputs": "...", "parameters": { "max_new_tokens": 512 } }
REMOTE_INFERENCE_URL=

# ── Model ────────────────────────────────────────────────────
# Default model to use for all requests.
# Options: claude-opus-4-6  claude-sonnet-4-6  claude-haiku-4-5-20251001
MODEL=claude-sonnet-4-6
MAX_TOKENS=1024

# ── Server ───────────────────────────────────────────────────
# Bind address. Use 127.0.0.1 for local-only (safe default).
# Set to 0.0.0.0 ONLY if you also set UI_AUTH_TOKEN below.
BIND_ADDR=127.0.0.1
PORT=8080

# ── Security ─────────────────────────────────────────────────
# Set a secret token to require ?token=... in the browser URL.
# Leave empty to disable authentication (local-only is safe).
# Example: UI_AUTH_TOKEN=my-secret-token-123
UI_AUTH_TOKEN=

# Rate limiting: max API requests per minute per IP address.
RATE_LIMIT_PER_MINUTE=20

# ── Conversation ─────────────────────────────────────────────
# Optional system prompt added to every conversation.
SYSTEM_PROMPT=

# Path to the SQLite database file for conversation history.
# Created automatically on first run.
DB_PATH=./data/conversations.db

# ── Swap (for low-RAM devices like phones) ───────────────────
# Size of swap file in MB. Set to 0 to disable.
# Requires root/sudo. Helps prevent OOM on 2-4 GB RAM devices.
SWAP_MB=0
SWAP_FILE=/swapfile_claude_proxy
